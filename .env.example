APP_NAME=LeagueSimulator
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Local: sqlite | Production: pgsql
DB_CONNECTION=pgsql
DB_URL= full connection URL (overrides individual vars below)
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync

# Allowed CORS origin. Use * for local dev, set to your frontend URL in production.
FRONTEND_URL=*
